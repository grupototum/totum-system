  "content": {
    "summary": "Procedimento completo para fazer deploy de aplicação React em VPS usando PM2 e Nginx como reverse proxy",
    "data": {
      "pre_requisitos": [
        "Node.js 18+ instalado",
        "PM2 instalado globalmente",
        "Nginx configurado",
        "Certificado SSL (opcional mas recomendado)"
      ],
      "passos": [
        {
          "ordem": 1,
          "acao": "Build da aplicação",
          "comando": "npm run build"
        },
        {
          "ordem": 2,
          "acao": "Copiar para pasta do servidor",
          "comando": "scp -r dist/ user@vps:/var/www/app/"
        },
        {
          "ordem": 3,
          "acao": "Configurar PM2",
          "comando": "pm2 start ecosystem.config.js"
        },
        {
          "ordem": 4,
          "acao": "Configurar Nginx",
          "arquivo": "/etc/nginx/sites-available/app"
        }
      ],
      "verificacao": [
        "Acessar URL e verificar se carrega",
        "Verificar SSL (https)",
        "Testar refresh em rotas (SPA)"
      ],
      "rollout": [
        "pm2 stop app",
        "pm2 delete app",
        "Restaurar backup se necessário"
      ]
    },
    "markdown": "# Deploy React na VPS\n\n## Pré-requisitos..."
  },

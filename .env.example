# ═════════════════════════════════════════════════════════════════════
# 🎬 TIKTOK API CONFIGURATION
# ═════════════════════════════════════════════════════════════════════

# Seu Client ID (obtido no TikTok Developer Console)
VITE_TIKTOK_CLIENT_ID=sua_client_id_aqui

# Seu Client Secret (obtido no TikTok Developer Console)
VITE_TIKTOK_CLIENT_SECRET=seu_client_secret_aqui

# Access Token da conta @totum (obtido via OAuth)
VITE_TIKTOK_ACCESS_TOKEN=seu_access_token_aqui

# Redirect URI após OAuth (deve estar registrada no TikTok Console)
VITE_TIKTOK_REDIRECT_URI=http://localhost:3000/auth/callback

# Modo: "sandbox" para testes ou "production" para real
VITE_TIKTOK_MODE=sandbox

# Refresh Token (para renovação automática, opcional)
VITE_TIKTOK_REFRESH_TOKEN=seu_refresh_token_aqui

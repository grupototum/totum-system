TELEGRAM_TOKEN=seu_telegram_bot_token_aqui
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# IDs dos responsáveis no Telegram (pegar via @userinfobot)
TELEGRAM_ID_SUPORTE=
TELEGRAM_ID_COMERCIAL=
TELEGRAM_ID_TECNICO=
TELEGRAM_ID_FINANCEIRO=
TELEGRAM_ID_DIRECAO=

# ═════════════════════════════════════════════════════════════════════
# 🔐 SUPABASE (obrigatório)
# ═════════════════════════════════════════════════════════════════════
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ═════════════════════════════════════════════════════════════════════
# 🤖 PROVEDORES DE IA
# ═════════════════════════════════════════════════════════════════════
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=
VITE_KIMI_API_KEY=
VITE_OPENAI_API_KEY=

# ═════════════════════════════════════════════════════════════════════
# 🌐 OAUTH / MULTI-TENANT
# ═════════════════════════════════════════════════════════════════════
VITE_GOOGLE_CLIENT_ID=
VITE_ROOT_DOMAIN=
VITE_TENANT_FALLBACK_HOST=

# ═════════════════════════════════════════════════════════════════════
# ⚙️ INTEGRAÇÕES E MONITORAMENTO
# ═════════════════════════════════════════════════════════════════════
VITE_OPENCLAW_URL=http://localhost:3000
VITE_OPENCLAW_MOCK=false
VITE_OLLAMA_URL=http://localhost:11434
VITE_BESZEL_URL=
VITE_UPTIME_KUMA_URL=
VITE_N8N_URL=
VITE_TELEGRAM_BOT_TOKEN=

# ═════════════════════════════════════════════════════════════════════
# 🎬 TIKTOK API CONFIGURATION
# ═════════════════════════════════════════════════════════════════════

# Seu Client ID (obtido no TikTok Developer Console)
VITE_TIKTOK_CLIENT_ID=sua_client_id_aqui

# Seu Client Secret (obtido no TikTok Developer Console)
VITE_TIKTOK_CLIENT_SECRET=seu_client_secret_aqui

# Access Token da conta @totum (obtido via OAuth)
VITE_TIKTOK_ACCESS_TOKEN=seu_access_token_aqui

# Redirect URI após OAuth (deve estar registrada no TikTok Console)
VITE_TIKTOK_REDIRECT_URI=http://localhost:3000/auth/callback

# Modo: "sandbox" para testes ou "production" para real
VITE_TIKTOK_MODE=sandbox

# Refresh Token (para renovação automática, opcional)
VITE_TIKTOK_REFRESH_TOKEN=seu_refresh_token_aqui

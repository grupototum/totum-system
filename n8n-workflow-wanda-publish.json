{
  "name": "WANDA - Publicar Posts Diariamente",
  "nodes": [
    {
      "parameters": {
        "interval": [
          {
            "triggerUnit": "hours",
            "triggerValue": 24
          }
        ]
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM wanda_posts WHERE published_at IS NULL ORDER BY created_at ASC LIMIT 1"
      },
      "id": "supabase-get-post",
      "name": "Get Unpublished Post",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [500, 300],
      "credentials": {
        "postgres": "supabase-connection"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://open.tiktokapis.com/v1/post/publish/",
        "authentication": "genericCredentialType",
        "genericCredentialType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.TIKTOK_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "jsonParameters": true,
        "body": {
          "title": "={{ $node['Get Unpublished Post'].json.subject }}",
          "description": "={{ $node['Get Unpublished Post'].json.hook }} {{ $node['Get Unpublished Post'].json.hashtags_string }}",
          "video_url": "https://totum.com.br/videos/{{ $node['Get Unpublished Post'].json.post_id }}.mp4",
          "disable_comment": false,
          "disable_duet": false,
          "disable_stitch": false
        }
      },
      "id": "tiktok-publish",
      "name": "Publish to TikTok",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [750, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE wanda_posts SET tiktok_video_id = '{{ $node['Publish to TikTok'].json.data.video_id }}', published_at = NOW(), last_updated_at = NOW() WHERE post_id = '{{ $node['Get Unpublished Post'].json.post_id }}'"
      },
      "id": "supabase-update-post",
      "name": "Update Post Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [1000, 300],
      "credentials": {
        "postgres": "supabase-connection"
      }
    },
    {
      "parameters": {
        "fromEmail": "{{ $env.EMAIL_GMAIL }}",
        "toEmail": "{{ $env.EMAIL_RECIPIENTS }}",
        "subject": "✅ Post WANDA Publicado no TikTok",
        "textContent": "Post: {{ $node['Get Unpublished Post'].json.subject }}\n\nViews esperadas: ~{{ $node['Get Unpublished Post'].json.views }}\nEngajamento: {{ $node['Get Unpublished Post'].json.engagement_rate }}%\n\nLink: https://www.tiktok.com/@totum.mkt/video/{{ $node['Publish to TikTok'].json.data.video_id }}"
      },
      "id": "send-email",
      "name": "Send Email Notification",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [1250, 300]
    },
    {
      "parameters": {
        "errorOutput": "last node with error",
        "triggerNode": "schedule-trigger"
      },
      "id": "error-handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [250, 500]
    },
    {
      "parameters": {
        "fromEmail": "{{ $env.EMAIL_GMAIL }}",
        "toEmail": "{{ $env.EMAIL_RECIPIENTS }}",
        "subject": "❌ Erro ao Publicar Post WANDA",
        "textContent": "Erro: {{ $node[error handler node].json.message }}\n\nPost: {{ $node['Get Unpublished Post'].json.subject }}\n\nVerifique o N8N para mais detalhes."
      },
      "id": "send-error-email",
      "name": "Send Error Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [500, 500]
    }
  ],
  "connections": {
    "schedule-trigger": {
      "main": [
        [
          {
            "node": "supabase-get-post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "supabase-get-post": {
      "main": [
        [
          {
            "node": "tiktok-publish",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "tiktok-publish": {
      "main": [
        [
          {
            "node": "supabase-update-post",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "supabase-update-post": {
      "main": [
        [
          {
            "node": "send-email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "error-handler": {
      "main": [
        [
          {
            "node": "send-error-email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
